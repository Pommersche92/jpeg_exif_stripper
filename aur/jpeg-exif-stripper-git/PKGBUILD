# Maintainer: Raimo Geisel <raimog92@protonmail.com>
pkgname=jpeg-exif-stripper-git
pkgver=r1.abcdef1
pkgrel=1
pkgdesc="A high-performance, lossless JPEG EXIF metadata removal utility (git)"
arch=('x86_64' 'aarch64' 'i686' 'armv7h')
url="https://github.com/Pommersche92/jpeg_exif_stripper"
license=('GPL-3.0-only')
depends=()
makedepends=('cargo' 'git')
provides=('jpeg-exif-stripper')
conflicts=('jpeg-exif-stripper' 'jpeg-exif-stripper-bin')
source=("jpeg_exif_stripper::git+https://github.com/Pommersche92/jpeg_exif_stripper.git")
sha256sums=('SKIP')

pkgver() {
    cd "jpeg_exif_stripper"
    git describe --long --tags --abbrev=7 2>/dev/null | sed 's/\([^-]*-g\)/r\1/;s/-/./g' \
        || printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
    cd "jpeg_exif_stripper"
    # Try locked first; fall back to unlocked for git checkouts without a Cargo.lock
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')" 2>/dev/null \
        || cargo fetch --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "jpeg_exif_stripper"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release
}

check() {
    cd "jpeg_exif_stripper"
    cargo test
}

package() {
    cd "jpeg_exif_stripper"
    install -Dm755 "target/release/jpeg_exif_stripper" "$pkgdir/usr/bin/jpeg_exif_stripper"
    install -Dm644 LICENSE.md "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
