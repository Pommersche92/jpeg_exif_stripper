# Maintainer: Raimo Geisel <raimog92@protonmail.com>
pkgname=jpeg-exif-stripper
pkgver=0.1.0
pkgrel=1
pkgdesc="A high-performance, lossless JPEG EXIF metadata removal utility"
arch=('x86_64' 'aarch64' 'i686' 'armv7h')
url="https://github.com/Pommersche92/jpeg_exif_stripper"
license=('GPL-3.0-only')
depends=()
makedepends=('cargo')
provides=('jpeg-exif-stripper')
conflicts=('jpeg-exif-stripper-bin' 'jpeg-exif-stripper-git')
source=("jpeg_exif_stripper-$pkgver.tar.gz::https://static.crates.io/crates/jpeg_exif_stripper/jpeg_exif_stripper-$pkgver.crate")
sha256sums=('PLACEHOLDER')

prepare() {
    cd "jpeg_exif_stripper-$pkgver"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "jpeg_exif_stripper-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --frozen
}

check() {
    cd "jpeg_exif_stripper-$pkgver"
    cargo test --frozen
}

package() {
    cd "jpeg_exif_stripper-$pkgver"
    install -Dm755 "target/release/jpeg_exif_stripper" "$pkgdir/usr/bin/jpeg_exif_stripper"
    install -Dm644 LICENSE.md "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
